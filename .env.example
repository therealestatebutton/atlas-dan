# Client Configuration
CLIENT_NAME=SC Leads
CLIENT_EMAIL=client@example.com
CLIENT_COUNTIES=[{"name":"Horry","state":"SC"},{"name":"Georgetown","state":"SC"},{"name":"Marion","state":"SC"}]

# SMTP Configuration (for email reports)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@atlasleads.example.com
EMAIL_RECIPIENTS=client@example.com

# Skip Trace API
SKIP_TRACE_KEY=your-skip-trace-api-key

# Scraper APIs (optional, for proxy/rate limiting)
SCRAPER_API_KEY=your-scraper-api-key
BRIGHT_DATA_USER=your-bright-data-user
BRIGHT_DATA_PASS=your-bright-data-pass
ATOM_API_KEY=your-atom-api-key

# Database
DATABASE_PATH=./data/leads.db

# Server
PORT=5000
NODE_ENV=development

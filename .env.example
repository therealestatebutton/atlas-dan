# Server Configuration
NODE_ENV=production
PORT=5000
DATABASE_PATH=./data/leads.db

# Client Configuration
CLIENT_NAME=Atlas SC Leads
CLIENT_EMAIL=leads@example.com
CLIENT_COUNTIES=[{"name":"Horry","state":"SC"},{"name":"Georgetown","state":"SC"},{"name":"Marion","state":"SC"}]

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@atlasleads.com
EMAIL_RECIPIENTS=client@example.com,admin@example.com

# API Keys
SKIP_TRACE_KEY=your-skip-trace-api-key
SCRAPER_API_KEY=your-scraper-api-key

# Bright Data (Optional)
BRIGHT_DATA_USER=your-bright-data-user
BRIGHT_DATA_PASS=your-bright-data-password

# Logging
LOG_LEVEL=info
